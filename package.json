{
  "name": "@samhess/svelte-components",
  "private": false,
  "version": "0.5.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samhess/svelte-components.git"
  },
  "homepage": "https://svelte-components-black.vercel.app",
  "keywords": [
    "svelte",
    "component",
    "datatable",
    "autocomplete"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "postinstall": "svelte-kit sync && prisma generate"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@prisma/client": "^7.6.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "chart.js": "^4.5.1",
    "chartjs-chart-sankey": "^0.14.0",
    "chartjs-chart-treemap": "^3.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.6.0",
    "publint": "^0.3.18",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "@lucide/svelte": "^1.7.0",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "svelte": "^5.55.1"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}